<script>
const COLORS = { pi:'#3b6ff0', tax:'#d4900a', ins:'#2da06b', pmi:'#d94f4f', hoa:'#8b5cf6', mip:'#d94f4f' };

function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }

function pmt(P, r, n) {
  if (!P || !n) return 0;
  if (r === 0) return P / n;
  return P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function switchTab(id) {
  const ids = ['conv','fha','va','refi','afford','dscr','buydown'];
  document.querySelectorAll('.tab').forEach((t, i) => t.classList.toggle('active', ids[i] === id));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
}

function switchSubtab(prefix, sub) {
  const subs = ['breakdown','chart','schedule'];
  const panelId = {c:'conv',f:'fha',v:'va',d:'dscr',b:'buydown'}[prefix];
  const panel = document.getElementById('panel-' + panelId);
  panel.querySelectorAll('.subtab').forEach((t, i) => t.classList.toggle('active', subs[i] === sub));
  subs.forEach(s => {
    const el = document.getElementById(prefix + '-sub-' + s);
    if (el) el.style.display = s === sub ? 'block' : 'none';
  });
}

function buildResult(total, rows) {
  const barParts = rows.map(r => `<div style="width:${(r.v/total*100).toFixed(1)}%;background:${COLORS[r.cls]};height:100%"></div>`).join('');
  const legend = rows.map(r => `<div class="leg-item"><div class="leg-dot" style="background:${COLORS[r.cls]}"></div>${r.label}</div>`).join('');
  const breakdown = rows.map(r => `<div class="breakdown-row"><span>${r.label}</span><span>${fmt(r.v)}</span></div>`).join('');
  return `<div class="result-label">Estimated Monthly Payment</div>
<div class="result-main">${fmt(total)}</div>
<div class="bar-wrap">${barParts}</div>
<div class="legend">${legend}</div>
<div class="breakdown">${breakdown}</div>`;
}

function buildBreakdown(rows) {
  return '<div class="breakdown">' + rows.map(r => `<div class="breakdown-row"><span>${r.label}</span><span>${fmt(r.v)}</span></div>`).join('') + '</div>';
}

function buildAmort(loan, r, n) {
  const mp = pmt(loan, r, n);
  let bal = loan, rows = [];
  for (let yr = 1; yr <= Math.ceil(n / 12); yr++) {
    let prin = 0, int = 0;
    const months = Math.min(12, n - (yr - 1) * 12);
    for (let m = 0; m < months; m++) {
      if (bal <= 0) break;
      const intM = bal * r;
      const p = mp - intM;
      prin += p; int += intM; bal = Math.max(0, bal - p);
    }
    rows.push({ yr, prin, int, bal });
  }
  return rows;
}

function amortTable(rows) {
  const trs = rows.map(r => `<tr><td>Year ${r.yr}</td><td>${fmt(r.prin)}</td><td>${fmt(r.int)}</td><td>${fmt(r.bal)}</td></tr>`).join('');
  return `<div class="amort-wrap"><table class="amort-table"><thead><tr><th>Year</th><th>Principal</th><th>Interest</th><th>Balance</th></tr></thead><tbody>${trs}</tbody></table></div>`;
}

function amortChart(rows) {
  const maxBal = rows[0] ? rows[0].bal + rows[0].prin + rows[0].int : 1;
  const W = 680, H = 160, padL = 10, padR = 10, padT = 10, padB = 30;
  const cW = W - padL - padR, cH = H - padT - padB;
  const xS = cW / (rows.length - 1 || 1);
  const yS = cH / maxBal;

  let balPts = '', intPts = '';
  rows.forEach((r, i) => {
    const x = padL + i * xS;
    balPts += `${x.toFixed(1)},${(padT + cH - r.bal * yS).toFixed(1)} `;
    intPts += `${x.toFixed(1)},${(padT + cH - r.int * yS).toFixed(1)} `;
  });

  const yLabels = [0, 0.5, 1].map(pct => {
    const val = maxBal * pct;
    const y = padT + cH - val * yS;
    return `<text x="${padL - 4}" y="${y.toFixed(1)}" font-size="10" fill="var(--text3)" text-anchor="end" dominant-baseline="middle">${val >= 1000 ? '$' + (val/1000).toFixed(0) + 'k' : '$0'}</text><line x1="${padL}" y1="${y.toFixed(1)}" x2="${W - padR}" y2="${y.toFixed(1)}" stroke="var(--border)" stroke-width="0.5"/>`;
  }).join('');

  return `<div class="chart-area">
<svg width="100%" viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">
${yLabels}
<polyline points="${balPts.trim()}" fill="none" stroke="#3b6ff0" stroke-width="2" stroke-linejoin="round"/>
<polyline points="${intPts.trim()}" fill="none" stroke="#d94f4f" stroke-width="1.5" stroke-dasharray="5,3" stroke-linejoin="round"/>
<text x="${padL}" y="${H - 6}" font-size="10" fill="var(--text3)">Yr 1</text>
<text x="${W - padR}" y="${H - 6}" font-size="10" fill="var(--text3)" text-anchor="end">Yr ${rows.length}</text>
</svg>
<div class="legend" style="margin-top:6px">
<div class="leg-item"><div class="leg-dot" style="background:#3b6ff0"></div>Remaining Balance</div>
<div class="leg-item"><div class="leg-dot" style="background:#d94f4f"></div>Annual Interest</div>
</div></div>`;
}

function fillSubtabs(prefix, loan, r, n) {
  const rows = buildAmort(loan, r, n);
  const chartEl = document.getElementById(prefix + '-sub-chart');
  const schedEl = document.getElementById(prefix + '-sub-schedule');
  if (chartEl) chartEl.innerHTML = amortChart(rows);
  if (schedEl) schedEl.innerHTML = amortTable(rows);
}

// Sync helpers
function syncConvDown(type) {
  const price = +document.getElementById('c-price').value || 0;
  if (type === '$') {
    const d = +document.getElementById('c-down').value || 0;
    document.getElementById('c-down-pct').value = price ? (d / price * 100).toFixed(1) : 0;
  } else {
    const pct = +document.getElementById('c-down-pct').value || 0;
    document.getElementById('c-down').value = Math.round(price * pct / 100);
  }
  calcConv();
}

function syncDown(p, type) {
  const price = +document.getElementById(p + '-price').value || 0;
  if (type === '$') {
    const d = +document.getElementById(p + '-down').value || 0;
    document.getElementById(p + '-down-pct').value = price ? (d / price * 100).toFixed(1) : 0;
  } else {
    const pct = +document.getElementById(p + '-down-pct').value || 0;
    document.getElementById(p + '-down').value = Math.round(price * pct / 100);
  }
  ({ f: calcFHA, v: calcVA, d: calcDSCR, b: calcBuydown })[p]();
}

// Calculators
function calcConv() {
  const price = +document.getElementById('c-price').value || 0;
  const down = +document.getElementById('c-down').value || 0;
  const loan = price - down;
  const r = (+document.getElementById('c-rate').value || 0) / 100 / 12;
  const n = +document.getElementById('c-term').value || 360;
  const tax = (+document.getElementById('c-tax').value || 0) / 12;
  const ins = (+document.getElementById('c-ins').value || 0) / 12;
  const hoa = +document.getElementById('c-hoa').value || 0;
  const dpPct = price ? down / price : 0;
  const pmi = dpPct < 0.2 ? loan * 0.008 / 12 : 0;
  const pi = pmt(loan, r, n);
  const total = pi + tax + ins + hoa + pmi;
  const rows = [
    { cls:'pi', label:'Principal & Interest', v:pi },
    { cls:'tax', label:'Property Tax', v:tax },
    { cls:'ins', label:'Home Insurance', v:ins },
  ];
  if (pmi > 0) rows.push({ cls:'pmi', label:'PMI', v:pmi });
  if (hoa > 0) rows.push({ cls:'hoa', label:'HOA', v:hoa });
  document.getElementById('c-result').innerHTML = buildResult(total, rows);
  document.getElementById('c-sub-breakdown').innerHTML = buildBreakdown(rows);
  fillSubtabs('c', loan, r, n);
}

function calcFHA() {
  const price = +document.getElementById('f-price').value || 0;
  const down = +document.getElementById('f-down').value || 0;
  const baseLoan = price - down;
  const ufmip = baseLoan * 0.0175;
  const loan = baseLoan + ufmip;
  const r = (+document.getElementById('f-rate').value || 0) / 100 / 12;
  const n = +document.getElementById('f-term').value || 360;
  const tax = (+document.getElementById('f-tax').value || 0) / 12;
  const ins = (+document.getElementById('f-ins').value || 0) / 12;
  const hoa = +document.getElementById('f-hoa').value || 0;
  const mip = baseLoan * 0.0055 / 12;
  const pi = pmt(loan, r, n);
  const total = pi + mip + tax + ins + hoa;
  const rows = [
    { cls:'pi', label:'Principal & Interest', v:pi },
    { cls:'mip', label:'Monthly MIP', v:mip },
    { cls:'tax', label:'Property Tax', v:tax },
    { cls:'ins', label:'Home Insurance', v:ins },
  ];
  if (hoa > 0) rows.push({ cls:'hoa', label:'HOA', v:hoa });
  let html = buildResult(total, rows);
  html += `<div class="breakdown-row" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border)"><span style="color:var(--text2)">Upfront MIP (rolled in)</span><span style="font-weight:500;font-family:var(--font-mono)">${fmt(ufmip)}</span></div>`;
  document.getElementById('f-result').innerHTML = html;
  document.getElementById('f-sub-breakdown').innerHTML = buildBreakdown(rows);
  fillSubtabs('f', loan, r, n);
}

function calcVA() {
  const price = +document.getElementById('v-price').value || 0;
  const down = +document.getElementById('v-down').value || 0;
  const baseLoan = price - down;
  const firstUse = document.querySelector('input[name="va-first"]:checked')?.value === 'yes';
  const disabled = document.querySelector('input[name="va-disabled"]:checked')?.value === 'yes';
  const dpPct = price ? down / price : 0;
  let feeRate = 0;
  if (!disabled) {
    if (firstUse) feeRate = dpPct >= 0.1 ? 0.014 : dpPct >= 0.05 ? 0.015 : 0.0215;
    else feeRate = dpPct >= 0.1 ? 0.014 : dpPct >= 0.05 ? 0.015 : 0.033;
  }
  const fee = baseLoan * feeRate;
  const loan = baseLoan + fee;
  const r = (+document.getElementById('v-rate').value || 0) / 100 / 12;
  const n = +document.getElementById('v-term').value || 360;
  const tax = (+document.getElementById('v-tax').value || 0) / 12;
  const ins = (+document.getElementById('v-ins').value || 0) / 12;
  const hoa = +document.getElementById('v-hoa').value || 0;
  const pi = pmt(loan, r, n);
  const total = pi + tax + ins + hoa;
  const rows = [
    { cls:'pi', label:'Principal & Interest', v:pi },
    { cls:'tax', label:'Property Tax', v:tax },
    { cls:'ins', label:'Home Insurance', v:ins },
  ];
  if (hoa > 0) rows.push({ cls:'hoa', label:'HOA', v:hoa });
  let html = buildResult(total, rows);
  if (fee > 0) html += `<div class="breakdown-row" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border)"><span style="color:var(--text2)">VA Funding Fee (${(feeRate*100).toFixed(2)}%, rolled in)</span><span style="font-weight:500;font-family:var(--font-mono)">${fmt(fee)}</span></div>`;
  document.getElementById('v-result').innerHTML = html;
  document.getElementById('v-sub-breakdown').innerHTML = buildBreakdown(rows);
  fillSubtabs('v', loan, r, n);
}

function calcRefi() {
  const curAmt = +document.getElementById('r-cur-amt').value || 0;
  const curRate = (+document.getElementById('r-cur-rate').value || 0) / 100 / 12;
  const curTerm = +document.getElementById('r-cur-term').value || 360;
  const newAmt = +document.getElementById('r-new-amt').value || 0;
  const newRate = (+document.getElementById('r-new-rate').value || 0) / 100 / 12;
  const newTerm = +document.getElementById('r-new-term').value || 360;
  const fees = +document.getElementById('r-fees').value || 0;
  const curPmt = pmt(curAmt, curRate, curTerm);
  const newPmt = pmt(newAmt, newRate, newTerm);
  const monthly = curPmt - newPmt;
  const lifetime = monthly * newTerm - fees;
  const be = monthly > 0 ? Math.ceil(fees / monthly) : null;
  let html = `<div class="result-label">Refinancing could save you</div>
<div class="result-main">${fmt(Math.max(0, monthly))}<span class="unit">/month</span></div>
<div class="breakdown" style="margin-top:14px">
<div class="breakdown-row"><span>New Monthly Payment</span><span>${fmt(newPmt)}</span></div>
<div class="breakdown-row"><span>Current Monthly Payment</span><span>${fmt(curPmt)}</span></div>
<div class="breakdown-row"><span>Refinance Fees</span><span>${fmt(fees)}</span></div>
<div class="breakdown-row"><span>Lifetime Savings</span><span>${fmt(Math.max(0, lifetime))}</span></div>
${be ? `<div class="breakdown-row"><span>Break-Even Point</span><span>${be} months</span></div>` : ''}
</div>`;
  if (monthly <= 0) html += `<div class="alert warn" style="margin-top:12px">Refinancing may not reduce your payment at these rates.</div>`;
  document.getElementById('r-result').innerHTML = html;
}

function calcAfford() {
  const income = +document.getElementById('a-income').value || 0;
  const debts = +document.getElementById('a-debts').value || 0;
  const tax = (+document.getElementById('a-tax').value || 0) / 12;
  const ins = (+document.getElementById('a-ins').value || 0) / 12;
  const down = +document.getElementById('a-down').value || 0;
  const r = (+document.getElementById('a-rate').value || 0) / 100 / 12;
  const n = +document.getElementById('a-term').value || 360;
  const maxMonthly = income / 12 * 0.43 - debts;
  const maxPI = maxMonthly - tax - ins;
  const maxLoan = maxPI > 0 && r > 0 ? maxPI * (1 - Math.pow(1 + r, -n)) / r : 0;
  const maxPrice = Math.max(0, maxLoan + down);
  document.getElementById('a-result').innerHTML = `
<div class="result-label">You can afford up to</div>
<div class="result-main">${fmt(maxPrice)}</div>
<div class="breakdown" style="margin-top:14px">
<div class="breakdown-row"><span>Max Monthly Housing (43% DTI)</span><span>${fmt(Math.max(0, maxMonthly))}</span></div>
<div class="breakdown-row"><span>Principal & Interest</span><span>${fmt(Math.max(0, maxPI))}</span></div>
<div class="breakdown-row"><span>Tax (monthly)</span><span>${fmt(tax)}</span></div>
<div class="breakdown-row"><span>Insurance (monthly)</span><span>${fmt(ins)}</span></div>
</div>`;
}

function calcDSCR() {
  const price = +document.getElementById('d-price').value || 0;
  const down = +document.getElementById('d-down').value || 0;
  const loan = price - down;
  const r = (+document.getElementById('d-rate').value || 0) / 100 / 12;
  const n = +document.getElementById('d-term').value || 360;
  const rent = +document.getElementById('d-rent').value || 0;
  const target = +document.getElementById('d-target').value || 1.25;
  const tax = (+document.getElementById('d-tax').value || 0) / 12;
  const ins = (+document.getElementById('d-ins').value || 0) / 12;
  const hoa = +document.getElementById('d-hoa').value || 0;
  const pi = pmt(loan, r, n);
  const totalExp = pi + tax + ins + hoa;
  const dscr = totalExp > 0 ? rent / totalExp : 0;
  const good = dscr >= target;
  const rows = [
    { cls:'pi', label:'Monthly P&I', v:pi },
    { cls:'tax', label:'Property Tax', v:tax },
    { cls:'ins', label:'Insurance', v:ins },
  ];
  if (hoa > 0) rows.push({ cls:'hoa', label:'HOA', v:hoa });
  let html = `<div class="result-label">Debt Service Coverage Ratio</div>
<div class="result-main">${dscr.toFixed(2)}</div>
<div class="alert ${good ? 'good' : 'warn'}" style="margin-top:10px">${good ? '✓ Meets target DSCR of ' + target : '✗ Below ' + target + ' target — may not qualify'}</div>
<div class="breakdown" style="margin-top:12px">
<div class="breakdown-row"><span>Monthly P&I</span><span>${fmt(pi)}</span></div>
<div class="breakdown-row"><span>Total Monthly Expenses</span><span>${fmt(totalExp)}</span></div>
<div class="breakdown-row"><span>Gross Monthly Rent</span><span>${fmt(rent)}</span></div>
<div class="breakdown-row"><span>Net Operating Income</span><span>${fmt(rent)}</span></div>
</div>`;
  document.getElementById('d-result').innerHTML = html;
  document.getElementById('d-sub-breakdown').innerHTML = buildBreakdown(rows);
  fillSubtabs('d', loan, r, n);
}

function calcBuydown() {
  const price = +document.getElementById('b-price').value || 0;
  const down = +document.getElementById('b-down').value || 0;
  const loan = price - down;
  const noteRate = (+document.getElementById('b-rate').value || 0) / 100;
  const n = +document.getElementById('b-term').value || 360;
  const tax = (+document.getElementById('b-tax').value || 0) / 12;
  const ins = (+document.getElementById('b-ins').value || 0) / 12;
  const hoa = +document.getElementById('b-hoa').value || 0;
  const r1 = (noteRate - 0.02) / 12;
  const r2 = (noteRate - 0.01) / 12;
  const r3 = noteRate / 12;
  const pi1 = pmt(loan, r1, n);
  const pi2 = pmt(loan, r2, n);
  const pi3 = pmt(loan, r3, n);
  const cost = 12 * (pi3 - pi1) + 12 * (pi3 - pi2);
  const t1 = pi1 + tax + ins + hoa;
  const t2 = pi2 + tax + ins + hoa;
  const t3 = pi3 + tax + ins + hoa;
  const yrs = Math.round(n / 12);
  document.getElementById('b-schedule-cards').innerHTML = `
<div class="buydown-card highlight">
  <div class="yr-tag">Year 1</div>
  <div class="yr-amt">${fmt(t1)}</div>
  <div class="yr-rate">${((noteRate - 0.02) * 100).toFixed(3).replace(/\.?0+$/, '')}% rate</div>
</div>
<div class="buydown-card">
  <div class="yr-tag">Year 2</div>
  <div class="yr-amt">${fmt(t2)}</div>
  <div class="yr-rate">${((noteRate - 0.01) * 100).toFixed(3).replace(/\.?0+$/, '')}% rate</div>
</div>
<div class="buydown-card">
  <div class="yr-tag">Years 3–${yrs}</div>
  <div class="yr-amt">${fmt(t3)}</div>
  <div class="yr-rate">${(noteRate * 100).toFixed(3).replace(/\.?0+$/, '')}% rate</div>
</div>`;
  const rows = [
    { cls:'pi', label:'Principal & Interest', v:pi3 },
    { cls:'tax', label:'Property Tax', v:tax },
    { cls:'ins', label:'Home Insurance', v:ins },
  ];
  if (hoa > 0) rows.push({ cls:'hoa', label:'HOA', v:hoa });
  let html = buildResult(t3, rows);
  html += `<div class="breakdown-row" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border)"><span style="color:var(--text2)">Buydown Cost (typically paid by seller/builder)</span><span style="font-weight:500;font-family:var(--font-mono)">${fmt(cost)}</span></div>`;
  document.getElementById('b-result').innerHTML = html;
  document.getElementById('b-sub-breakdown').innerHTML = buildBreakdown(rows);
  fillSubtabs('b', loan, r3, n);
}

// Init
calcConv(); calcFHA(); calcVA(); calcRefi(); calcAfford(); calcDSCR(); calcBuydown();
</script>
