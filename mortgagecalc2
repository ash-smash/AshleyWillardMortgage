<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mortgage Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --bg2: #f7f7f5;
    --bg3: #f0efe9;
    --text: #1a1a18;
    --text2: #5c5c58;
    --text3: #9a9a94;
    --border: #e2e2dc;
    --border2: #ccccc4;
    --accent: #1a4fdb;
    --accent-light: #eef1fd;
    --accent-text: #1a4fdb;
    --success: #0f7a4a;
    --success-bg: #edf7f2;
    --warning: #a14d00;
    --warning-bg: #fff4ec;
    --radius: 8px;
    --radius-lg: 12px;
    --font: 'DM Sans', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    font-size: 15px;
    line-height: 1.5;
  }

  .calc-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .calc-header {
    margin-bottom: 1.75rem;
  }

  .calc-header h1 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 4px;
  }

  .calc-header p {
    font-size: 14px;
    color: var(--text2);
  }

  /* Tabs */
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }

  .tab {
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    font-family: var(--font);
    border: none;
    background: none;
    color: var(--text2);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color .15s, border-color .15s;
    border-radius: 0;
  }

  .tab:hover { color: var(--text); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .panel { display: none; }
  .panel.active { display: block; }

  /* Grid */
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }

  @media (max-width: 560px) {
    .grid2, .grid3 { grid-template-columns: 1fr; }
  }

  /* Fields */
  .field { display: flex; flex-direction: column; gap: 6px; }

  label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text2);
    letter-spacing: .03em;
    text-transform: uppercase;
  }

  .input-row {
    display: flex;
    align-items: center;
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg);
    transition: border-color .15s;
  }

  .input-row:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(26,79,219,.08);
  }

  .prefix, .suffix {
    padding: 0 11px;
    font-size: 14px;
    color: var(--text3);
    background: var(--bg2);
    height: 40px;
    display: flex;
    align-items: center;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .suffix { border-right: none; border-left: 1px solid var(--border); }

  .input-row input, .input-row select {
    border: none;
    outline: none;
    background: transparent;
    padding: 0 12px;
    height: 40px;
    font-size: 14px;
    color: var(--text);
    width: 100%;
    font-family: var(--font);
    min-width: 0;
  }

  .input-row input[type="number"] { font-family: var(--font-mono); }
  select { cursor: pointer; }

  .hint {
    font-size: 12px;
    color: var(--text3);
    font-style: italic;
    margin-top: 4px;
  }

  hr.divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: .875rem;
  }

  /* Result card */
  .result-card {
    background: var(--bg2);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0 1rem;
  }

  .result-label {
    font-size: 12px;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: .04em;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .result-main {
    font-size: 36px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.03em;
    font-family: var(--font-mono);
  }

  .result-main .unit {
    font-size: 16px;
    font-weight: 400;
    color: var(--text2);
    font-family: var(--font);
    letter-spacing: 0;
  }

  .breakdown {
    margin-top: 14px;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .breakdown-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--text2);
  }

  .breakdown-row span:last-child {
    color: var(--text);
    font-weight: 500;
    font-family: var(--font-mono);
  }

  /* Bar */
  .bar-wrap {
    display: flex;
    height: 6px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg3);
    margin: 14px 0 10px;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 4px;
  }

  .leg-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text2);
  }

  .leg-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Subtabs */
  .subtabs {
    display: flex;
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    overflow: hidden;
    margin: 1rem 0 .75rem;
  }

  .subtab {
    flex: 1;
    padding: 8px 10px;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font);
    cursor: pointer;
    background: var(--bg);
    color: var(--text2);
    border: none;
    transition: background .12s, color .12s;
    text-align: center;
  }

  .subtab:not(:last-child) { border-right: 1px solid var(--border2); }
  .subtab.active { background: var(--text); color: var(--bg); }

  /* Amortization */
  .amort-wrap {
    max-height: 280px;
    overflow-y: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .amort-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .amort-table th {
    position: sticky;
    top: 0;
    background: var(--bg2);
    text-align: left;
    padding: 9px 14px;
    color: var(--text2);
    font-weight: 500;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
    z-index: 1;
  }

  .amort-table td {
    padding: 8px 14px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text);
  }

  .amort-table tr:last-child td { border: none; }
  .amort-table tr:hover td { background: var(--bg2); }

  /* Chart */
  .chart-area {
    padding: 1rem 0;
    overflow: hidden;
  }

  /* Radio */
  .radio-group { display: flex; gap: 16px; flex-wrap: wrap; margin-top: 4px; }

  .radio-group label {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: var(--text);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    cursor: pointer;
  }

  .radio-group input {
    accent-color: var(--accent);
    width: 15px;
    height: 15px;
    cursor: pointer;
  }

  /* Alerts */
  .alert {
    padding: 10px 14px;
    border-radius: var(--radius);
    font-size: 13px;
    margin-top: 10px;
    border: 1px solid;
  }

  .alert.warn { background: var(--warning-bg); color: var(--warning); border-color: #f5cba2; }
  .alert.good { background: var(--success-bg); color: var(--success); border-color: #a3d9be; }

  /* Buydown cards */
  .buydown-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin: 1rem 0; }

  .buydown-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
    text-align: center;
  }

  .buydown-card .yr-tag {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text3);
    font-weight: 500;
    margin-bottom: 6px;
  }

  .buydown-card .yr-amt {
    font-size: 22px;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .buydown-card .yr-rate {
    font-size: 12px;
    color: var(--text2);
    margin-top: 3px;
  }

  .buydown-card.highlight { border-color: var(--accent); background: var(--accent-light); }
  .buydown-card.highlight .yr-amt { color: var(--accent-text); }

  /* Disclaimer */
  .disclaimer {
    font-size: 11px;
    color: var(--text3);
    line-height: 1.6;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  /* Down payment split input */
  .down-row {
    display: flex;
    align-items: center;
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg);
    transition: border-color .15s;
  }
  .down-row:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,79,219,.08); }
  .down-row .prefix { border-right: 1px solid var(--border); }
  .down-row input.pct-in { width: 56px; border-left: 1px solid var(--border); padding: 0 8px; }
  .down-row .suffix { border-left: 1px solid var(--border); }
</style>
</head>
<body>

<div class="calc-wrap">
  <div class="calc-header">
    <h1>Mortgage Calculator</h1>
    <p>Estimate your monthly mortgage payment</p>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('conv')">Conventional</button>
    <button class="tab" onclick="switchTab('fha')">FHA</button>
    <button class="tab" onclick="switchTab('va')">VA</button>
    <button class="tab" onclick="switchTab('refi')">Refinance</button>
    <button class="tab" onclick="switchTab('afford')">Affordability</button>
    <button class="tab" onclick="switchTab('dscr')">DSCR</button>
    <button class="tab" onclick="switchTab('buydown')">2-1 Buydown</button>
  </div>

  <!-- CONVENTIONAL -->
  <div class="panel active" id="panel-conv">
    <p class="section-label">Loan Details</p>
    <div class="grid2">
      <div class="field"><label>Home Price</label><div class="input-row"><span class="prefix">$</span><input type="number" id="c-price" value="350000" oninput="syncConvDown('$')"></div></div>
      <div class="field"><label>Down Payment</label>
        <div class="down-row"><span class="prefix">$</span><input type="number" id="c-down" value="70000" oninput="syncConvDown('$')"><input type="number" id="c-down-pct" class="pct-in" value="20" min="0" max="100" oninput="syncConvDown('%')"><span class="suffix">%</span></div>
      </div>
      <div class="field"><label>Loan Term</label><div class="input-row"><select id="c-term" onchange="calcConv()"><option value="360">30-Year Fixed</option><option value="240">20-Year Fixed</option><option value="180">15-Year Fixed</option><option value="120">10-Year Fixed</option></select></div></div>
      <div class="field"><label>Interest Rate</label><div class="input-row"><input type="number" id="c-rate" value="6.5" step="0.125" oninput="calcConv()"><span class="suffix">%</span></div></div>
    </div>
    <p class="hint">Connect with your Loan Officer for the most accurate rates</p>
    <hr class="divider">
    <p class="section-label">Additional Costs</p>
    <div class="grid3">
      <div class="field"><label>Annual Property Tax</label><div class="input-row"><span class="prefix">$</span><input type="number" id="c-tax" value="4200" oninput="calcConv()"></div></div>
      <div class="field"><label>Annual Home Insurance</label><div class="input-row"><span class="prefix">$</span><input type="number" id="c-ins" value="1500" oninput="calcConv()"></div></div>
      <div class="field"><label>Monthly HOA Fees</label><div class="input-row"><span class="prefix">$</span><input type="number" id="c-hoa" value="0" oninput="calcConv()"></div></div>
    </div>
    <hr class="divider">
    <p class="section-label">Credit &amp; PMI</p>
    <div class="field" style="max-width:300px">
      <label>Credit Score</label>
      <div class="input-row"><select id="c-credit" onchange="calcConv()">
        <option value="780">780+ (Excellent)</option><option value="760">760-779 (Excellent)</option>
        <option value="740">740-759 (Very Good)</option><option value="720" selected>720-739 (Good)</option>
        <option value="700">700-719 (Good)</option><option value="680">680-699 (Fair)</option>
        <option value="660">660-679 (Fair)</option><option value="640">640-659 (Below Average)</option>
        <option value="620">620-639 (Poor)</option>
      </select></div>
    </div>
    <p class="hint" style="margin-top:6px">PMI is auto-calculated when down payment is less than 20%</p>
    <hr class="divider">
    <p class="section-label">Extra Payments</p>
    <div class="field" style="max-width:280px"><label>Extra Monthly Principal Payment</label><div class="input-row"><span class="prefix">$</span><input type="number" id="c-extra" value="0" oninput="calcConv()"></div></div>
    <p class="hint" style="margin-top:4px">See how extra payments reduce your loan payoff time</p>
    <div class="result-card" id="c-result"></div>
    <div class="subtabs">
      <button class="subtab active" onclick="switchSubtab('c','breakdown')">Payment Breakdown</button>
      <button class="subtab" onclick="switchSubtab('c','chart')">Amortization Chart</button>
      <button class="subtab" onclick="switchSubtab('c','schedule')">Schedule</button>
    </div>
    <div id="c-sub-breakdown"></div>
    <div id="c-sub-chart" style="display:none"></div>
    <div id="c-sub-schedule" style="display:none"></div>
  </div>

  <!-- FHA -->
  <div class="panel" id="panel-fha">
    <p class="section-label">FHA Loan Details</p>
    <div class="grid2">
      <div class="field"><label>Home Price</label><div class="input-row"><span class="prefix">$</span><input type="number" id="f-price" value="350000" oninput="syncDown('f','$')"></div></div>
      <div class="field"><label>Down Payment</label>
        <div class="down-row"><span class="prefix">$</span><input type="number" id="f-down" value="12250" oninput="syncDown('f','$')"><input type="number" id="f-down-pct" class="pct-in" value="3.5" step="0.5" oninput="syncDown('f','%')"><span class="suffix">%</span></div>
      </div>
      <div class="field"><label>Loan Term</label><div class="input-row"><select id="f-term" onchange="calcFHA()"><option value="360">30-Year Fixed</option><option value="240">20-Year Fixed</option><option value="180">15-Year Fixed</option><option value="120">10-Year Fixed</option></select></div></div>
      <div class="field"><label>Interest Rate</label><div class="input-row"><input type="number" id="f-rate" value="6.5" step="0.125" oninput="calcFHA()"><span class="suffix">%</span></div></div>
    </div>
    <p class="hint">Connect with your Loan Officer for the most accurate rates</p>
    <hr class="divider">
    <p class="section-label">Additional Costs</p>
    <div class="grid3">
      <div class="field"><label>Annual Property Tax</label><div class="input-row"><span class="prefix">$</span><input type="number" id="f-tax" value="4200" oninput="calcFHA()"></div></div>
      <div class="field"><label>Annual Home Insurance</label><div class="input-row"><span class="prefix">$</span><input type="number" id="f-ins" value="1500" oninput="calcFHA()"></div></div>
      <div class="field"><label>Monthly HOA Fees</label><div class="input-row"><span class="prefix">$</span><input type="number" id="f-hoa" value="0" oninput="calcFHA()"></div></div>
    </div>
    <div class="result-card" id="f-result"></div>
    <div class="subtabs">
      <button class="subtab active" onclick="switchSubtab('f','breakdown')">Payment Breakdown</button>
      <button class="subtab" onclick="switchSubtab('f','chart')">Amortization Chart</button>
      <button class="subtab" onclick="switchSubtab('f','schedule')">Schedule</button>
    </div>
    <div id="f-sub-breakdown"></div>
    <div id="f-sub-chart" style="display:none"></div>
    <div id="f-sub-schedule" style="display:none"></div>
  </div>

  <!-- VA -->
  <div class="panel" id="panel-va">
    <p class="section-label">VA Loan Details</p>
    <div class="grid2">
      <div class="field"><label>Home Price</label><div class="input-row"><span class="prefix">$</span><input type="number" id="v-price" value="350000" oninput="syncDown('v','$')"></div></div>
      <div class="field"><label>Down Payment</label>
        <div class="down-row"><span class="prefix">$</span><input type="number" id="v-down" value="0" oninput="syncDown('v','$')"><input type="number" id="v-down-pct" class="pct-in" value="0" oninput="syncDown('v','%')"><span class="suffix">%</span></div>
      </div>
      <div class="field"><label>Loan Term</label><div class="input-row"><select id="v-term" onchange="calcVA()"><option value="360">30-Year Fixed</option><option value="240">20-Year Fixed</option><option value="180">15-Year Fixed</option><option value="120">10-Year Fixed</option></select></div></div>
      <div class="field"><label>Interest Rate</label><div class="input-row"><input type="number" id="v-rate" value="6.5" step="0.125" oninput="calcVA()"><span class="suffix">%</span></div></div>
    </div>
    <p class="hint">Connect with your Loan Officer for the most accurate rates</p>
    <hr class="divider">
    <p class="section-label">VA Options</p>
    <div class="grid2">
      <div class="field"><label>First Time Use?</label><div class="radio-group"><label><input type="radio" name="va-first" value="yes" checked onchange="calcVA()"> Yes</label><label><input type="radio" name="va-first" value="no" onchange="calcVA()"> No</label></div></div>
      <div class="field"><label>Disabled Veteran?</label><div class="radio-group"><label><input type="radio" name="va-disabled" value="no" checked onchange="calcVA()"> No</label><label><input type="radio" name="va-disabled" value="yes" onchange="calcVA()"> Yes</label></div></div>
    </div>
    <p class="hint">Disabled veterans are exempt from the VA funding fee</p>
    <hr class="divider">
    <p class="section-label">Additional Costs</p>
    <div class="grid3">
      <div class="field"><label>Annual Property Tax</label><div class="input-row"><span class="prefix">$</span><input type="number" id="v-tax" value="4200" oninput="calcVA()"></div></div>
      <div class="field"><label>Annual Home Insurance</label><div class="input-row"><span class="prefix">$</span><input type="number" id="v-ins" value="1500" oninput="calcVA()"></div></div>
      <div class="field"><label>Monthly HOA Fees</label><div class="input-row"><span class="prefix">$</span><input type="number" id="v-hoa" value="0" oninput="calcVA()"></div></div>
    </div>
    <div class="result-card" id="v-result"></div>
    <div class="subtabs">
      <button class="subtab active" onclick="switchSubtab('v','breakdown')">Payment Breakdown</button>
      <button class="subtab" onclick="switchSubtab('v','chart')">Amortization Chart</button>
      <button class="subtab" onclick="switchSubtab('v','schedule')">Schedule</button>
    </div>
    <div id="v-sub-breakdown"></div>
    <div id="v-sub-chart" style="display:none"></div>
    <div id="v-sub-schedule" style="display:none"></div>
  </div>

  <!-- REFINANCE -->
  <div class="panel" id="panel-refi">
    <p class="section-label">Current Loan</p>
    <div class="grid2">
      <div class="field"><label>Current Loan Amount</label><div class="input-row"><span class="prefix">$</span><input type="number" id="r-cur-amt" value="280000" oninput="calcRefi()"></div></div>
      <div class="field"><label>Current Interest Rate</label><div class="input-row"><input type="number" id="r-cur-rate" value="7.5" step="0.125" oninput="calcRefi()"><span class="suffix">%</span></div></div>
      <div class="field"><label>Months Remaining</label><div class="input-row"><input type="number" id="r-cur-term" value="324" oninput="calcRefi()"></div></div>
    </div>
    <hr class="divider">
    <p class="section-label">New Loan</p>
    <div class="grid2">
      <div class="field"><label>New Loan Amount</label><div class="input-row"><span class="prefix">$</span><input type="number" id="r-new-amt" value="280000" oninput="calcRefi()"></div></div>
      <div class="field"><label>New Interest Rate</label><div class="input-row"><input type="number" id="r-new-rate" value="6.0" step="0.125" oninput="calcRefi()"><span class="suffix">%</span></div></div>
      <div class="field"><label>New Term (months)</label><div class="input-row"><input type="number" id="r-new-term" value="360" oninput="calcRefi()"></div></div>
      <div class="field"><label>Refinance Fees</label><div class="input-row"><span class="prefix">$</span><input type="number" id="r-fees" value="4000" oninput="calcRefi()"></div></div>
    </div>
    <p class="hint">Connect with your Loan Officer for the most accurate rates</p>
    <div class="result-card" id="r-result"></div>
  </div>

  <!-- AFFORDABILITY -->
  <div class="panel" id="panel-afford">
    <p class="section-label">Your Finances</p>
    <div class="grid2">
      <div class="field"><label>Annual Income</label><div class="input-row"><span class="prefix">$</span><input type="number" id="a-income" value="100000" oninput="calcAfford()"></div></div>
      <div class="field"><label>Monthly Debts</label><div class="input-row"><span class="prefix">$</span><input type="number" id="a-debts" value="500" oninput="calcAfford()"></div></div>
      <div class="field"><label>Est. Annual Property Taxes</label><div class="input-row"><span class="prefix">$</span><input type="number" id="a-tax" value="4200" oninput="calcAfford()"></div></div>
